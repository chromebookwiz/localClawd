    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "cli-highlight": "^2.1.11",
    "code-excerpt": "^4.0.0",
    "commander": "^14.0.3",
