    "yaml": "^2.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "zod": "^4.1.12"
  },
  "resolutions": {
    "zod": "^4.1.12"
  }
}
